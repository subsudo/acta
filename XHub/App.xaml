<Application x:Class="XHub.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="Brush.WindowBg" Color="#485161" />
        <SolidColorBrush x:Key="Brush.PanelBg" Color="#556072" />
        <SolidColorBrush x:Key="Brush.CardBg" Color="#647084" />
        <SolidColorBrush x:Key="Brush.CardHover" Color="#748199" />
        <SolidColorBrush x:Key="Brush.PrimaryText" Color="#F5F7FA" />
        <SolidColorBrush x:Key="Brush.SecondaryText" Color="#CCD4E0" />
        <SolidColorBrush x:Key="Brush.SubtleText" Color="#9CA7B8" />
        <SolidColorBrush x:Key="Brush.Border" Color="#7A879C" />
        <SolidColorBrush x:Key="Brush.Accent" Color="#8EA9CE" />
        <SolidColorBrush x:Key="Brush.AccentHover" Color="#A4BDE0" />
        <SolidColorBrush x:Key="Brush.AccentPressed" Color="#7996BA" />
        <SolidColorBrush x:Key="Brush.AccentSubtle" Color="#5A6F90" />
        <SolidColorBrush x:Key="Brush.SoftSurface" Color="#6C778A" />
        <SolidColorBrush x:Key="Brush.Success" Color="#34D399" />
        <SolidColorBrush x:Key="Brush.Warning" Color="#FBBF24" />
        <SolidColorBrush x:Key="Brush.ArchiveBadgeBg" Color="#451A03" />
        <SolidColorBrush x:Key="Brush.ArchiveBadgeText" Color="#FDE68A" />
        <SolidColorBrush x:Key="Brush.StartBadgeBg" Color="#172554" />
        <SolidColorBrush x:Key="Brush.StartBadgeText" Color="#BFDBFE" />
        <SolidColorBrush x:Key="Brush.Error" Color="#F87171" />
        <SolidColorBrush x:Key="Brush.Info" Color="#60A5FA" />
        <SolidColorBrush x:Key="Brush.ScrollTrack" Color="#E1E6ED" />
        <SolidColorBrush x:Key="Brush.ScrollThumb" Color="#7A8599" />
        <SolidColorBrush x:Key="Brush.ScrollThumbHover" Color="#93A0B5" />
        <SolidColorBrush x:Key="Brush.ScrollThumbDrag" Color="#A3AFC2" />


        <Style x:Key="MinimalScrollBarButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MinimalScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource Brush.ScrollThumb}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Margin="1"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                MinHeight="24"
                                MinWidth="24" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource Brush.ScrollThumbHover}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource Brush.ScrollThumbDrag}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="TrackBorder"
                                    Background="{DynamicResource Brush.ScrollTrack}"
                                    CornerRadius="3"
                                    Margin="1" />
                            <Track x:Name="PART_Track"
                                   Focusable="False"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource MinimalScrollBarButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource MinimalScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource MinimalScrollBarButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                                <Setter TargetName="TrackBorder" Property="Height" Value="6" />
                                <Setter TargetName="TrackBorder" Property="VerticalAlignment" Value="Center" />
                            </Trigger>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter TargetName="TrackBorder" Property="Width" Value="6" />
                                <Setter TargetName="TrackBorder" Property="HorizontalAlignment" Value="Center" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="8" />
                    <Setter Property="MinWidth" Value="8" />
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="8" />
                    <Setter Property="MinHeight" Value="8" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="{DynamicResource Ui.Font.Control}" />
            <Setter Property="Background" Value="{DynamicResource Brush.CardBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="{DynamicResource Ui.Font.Control}" />
            <Setter Property="Background" Value="{DynamicResource Brush.CardBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="{DynamicResource Ui.Font.Control}" />
            <Setter Property="Background" Value="{DynamicResource Brush.CardBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="FontSize" Value="{DynamicResource Ui.Font.Control}" />
            <Setter Property="Background" Value="{DynamicResource Brush.PanelBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="{DynamicResource Ui.Font.Control}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="FontSize" Value="{DynamicResource Ui.Font.Control}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource Brush.PanelBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="FontSize" Value="{DynamicResource Ui.Font.Control}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="Padding" Value="10,6" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.AccentSubtle}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
