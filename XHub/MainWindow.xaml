<Window x:Class="XHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:XHub.Models"
        xmlns:controls="clr-namespace:XHub.Controls"
        xmlns:converters="clr-namespace:XHub.Converters"
        mc:Ignorable="d"
        Title="Acta"
        Icon="pack://application:,,,/Assets/icon.ico"
        Width="1280"
        Height="780"
        MinWidth="520"
        MinHeight="520"
        Background="{DynamicResource Brush.WindowBg}"
        Foreground="{DynamicResource Brush.PrimaryText}">
    <Window.Resources>
        <converters:QuickActionVisibilityConverter x:Key="QuickActionVisibilityConverter" />
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />

        <Style TargetType="Border" x:Key="PanelBorderStyle">
            <Setter Property="Background" Value="{DynamicResource Brush.PanelBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButtonStyle">
            <Setter Property="Background" Value="{DynamicResource Brush.CardBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="{DynamicResource Ui.Padding.SecondaryButton}" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.CardHover}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryButtonStyle" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style TargetType="Button" x:Key="IconButtonStyle" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="{DynamicResource Ui.Size.IconButton}" />
            <Setter Property="Height" Value="{DynamicResource Ui.Size.IconButton}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="{DynamicResource Ui.Font.IconAction}" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style TargetType="Button" x:Key="ScaleAdjustButtonStyle" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="{DynamicResource Ui.Size.IconButton}" />
            <Setter Property="Height" Value="{DynamicResource Ui.Size.IconButton}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="{DynamicResource Ui.Font.IconAction}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="GhostButtonStyle" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style TargetType="Button" x:Key="QuickActionButtonStyle" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Padding" Value="{DynamicResource Ui.Padding.QuickAction}" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="FontSize" Value="{DynamicResource Ui.Font.QuickAction}" />
            <Setter Property="MinWidth" Value="{DynamicResource Ui.Size.QuickActionMinWidth}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="ArchiveSearchButtonStyle" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="{DynamicResource Ui.Font.Control}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.SecondaryText}" />
            <Setter Property="MinWidth" Value="46" />
            <Setter Property="Height" Value="19" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsArchiveSearchEnabled, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.AccentSubtle}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                    <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsArchiveLoading, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Opacity" Value="0.7" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="ParticipantInitialsTextStyle">
            <Setter Property="FontSize" Value="{DynamicResource Ui.Font.ParticipantInitials}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.SecondaryText}" />
            <Setter Property="Margin" Value="0,-1,0,2" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Initials}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Setter Property="Margin" Value="0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="ParticipantNameTextStyle">
            <Setter Property="FontSize" Value="{DynamicResource Ui.Font.ParticipantName}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
        </Style>

        <Style TargetType="TextBlock" x:Key="ParticipantNameWithInitialsTextStyle" BasedOn="{StaticResource ParticipantNameTextStyle}">
        </Style>

        <Style TargetType="TextBlock" x:Key="ParticipantNameWithoutInitialsTextStyle" BasedOn="{StaticResource ParticipantNameTextStyle}">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="StackPanel" x:Key="ParticipantTextWithInitialsPanelStyle">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Initials}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="ParticipantTextWithoutInitialsStyle" BasedOn="{StaticResource ParticipantNameWithoutInitialsTextStyle}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Initials}" Value="">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ItemsControl" x:Key="ParticipantHintMarkerItemsStyle">
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasActiveHints}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="StackPanel" x:Key="ParticipantTextWithoutInitialsPanelStyle">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Initials}" Value="">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="StatusTagBadgeStyle">
            <Setter Property="Background" Value="{DynamicResource Brush.WindowBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="MinWidth" Value="{DynamicResource Ui.Size.StatusTagMinWidth}" />
            <Setter Property="Height" Value="{DynamicResource Ui.Size.StatusTagHeight}" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusTag}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding DataContext.ShowStatusTags, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                        <Condition Binding="{Binding IsArchived}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Collapsed" />
                </MultiDataTrigger>
                <DataTrigger Binding="{Binding IsArchived}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.ArchiveBadgeBg}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.ArchiveBadgeBg}" />
                    <Setter Property="MinWidth" Value="48" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTag}" Value="ST">
                    <Setter Property="Background" Value="{DynamicResource Brush.StartBadgeBg}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.StartBadgeBg}" />
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="StatusTagTextStyle">
            <Setter Property="FontSize" Value="{DynamicResource Ui.Font.QuickAction}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.SecondaryText}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsArchived}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Brush.ArchiveBadgeText}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTag}" Value="ST">
                    <Setter Property="Foreground" Value="{DynamicResource Brush.StartBadgeText}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Grid" x:Key="StatusTextColumnStyle">
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="31" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusTag}" Value="">
                    <Setter Property="Margin" Value="-40,0,0,0" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding DataContext.ShowStatusTags, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                        <Condition Binding="{Binding IsArchived}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Margin" Value="-40,0,0,0" />
                </MultiDataTrigger>
                <DataTrigger Binding="{Binding StatusTag}" Value="ST">
                    <Setter Property="Margin" Value="0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox" x:Key="SearchTextBoxStyle">
            <Setter Property="Background" Value="{DynamicResource Brush.CardBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="{DynamicResource Ui.Padding.SearchTextBox}" />
            <Setter Property="FontSize" Value="{DynamicResource Ui.Font.Search}" />
        </Style>

        <Style x:Key="SubtleProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="#7FAF86" />
            <Setter Property="Background" Value="{DynamicResource Brush.WindowBg}" />
            <Setter Property="Height" Value="6" />
            <Setter Property="Width" Value="72" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="3">
                            <Grid ClipToBounds="True">
                                <Rectangle x:Name="Indicator"
                                           Width="30"
                                           Fill="{TemplateBinding Foreground}"
                                           Opacity="0.8"
                                           HorizontalAlignment="Left">
                                    <Rectangle.RenderTransform>
                                        <TranslateTransform X="-34" />
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="ProgressStoryboard">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="Indicator"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             From="-34"
                                                             To="108"
                                                             Duration="0:0:1.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="ProgressStoryboard" />
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem" x:Key="SidebarListItemStyle">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="{DynamicResource Ui.Margin.SidebarItemBottom}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{DynamicResource Brush.CardBg}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{DynamicResource Ui.Padding.SidebarItem}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Brush.AccentSubtle}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Brush.CardHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem" x:Key="ParticipantListItemStyle">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="{DynamicResource Ui.Margin.ParticipantItemBottom}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{DynamicResource Brush.CardBg}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="{DynamicResource Ui.Padding.ParticipantItem}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem" x:Key="WorkingListItemStyle">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="{DynamicResource Ui.Margin.WorkingItemBottom}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{DynamicResource Brush.CardBg}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="{DynamicResource Ui.Padding.WorkingItem}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True" />
                                    <Condition Binding="{Binding DataContext.IsDetailPanelOpen, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Brush.CardHover}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                            </MultiDataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Brush.CardHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid x:Name="RootGrid" Margin="10" PreviewMouseDown="RootGrid_OnPreviewMouseDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border x:Name="TopBarBorder"
                Grid.Row="0"
                Background="{DynamicResource Brush.WindowBg}"
                BorderBrush="Transparent"
                BorderThickness="0"
                Padding="14,4,12,10">
            <Grid x:Name="TopBarLayoutGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        x:Name="ToggleListPanelButton"
                        Style="{StaticResource IconButtonStyle}"
                        Content="☰"
                        ToolTip="Listen ein-/ausblenden"
                        Click="ToggleListPanelButton_OnClick"
                        Margin="0,0,8,0" />

                <Grid x:Name="TopBarSearchArea" Grid.Column="1" Margin="0,0,8,0">
                    <TextBox x:Name="SearchTextBox"
                             Style="{StaticResource SearchTextBoxStyle}"
                             VerticalAlignment="Center"
                             TextChanged="SearchTextBox_OnTextChanged"
                             GotKeyboardFocus="SearchTextBox_OnGotKeyboardFocus" />
                    <TextBlock x:Name="SearchPlaceholder"
                               Text="Teilnehmende suchen..."
                               IsHitTestVisible="False"
                               Foreground="{DynamicResource Brush.SubtleText}"
                               VerticalAlignment="Center"
                               Margin="30,0,0,0"
                               FontSize="{DynamicResource Ui.Font.Search}" />
                    <Button x:Name="ClearSearchButton"
                            Width="22" Height="22"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="5,0,0,0"
                            Style="{StaticResource GhostButtonStyle}"
                            FontSize="{DynamicResource Ui.Font.IconAction}"
                            Padding="0"
                            Content="×"
                            Visibility="Collapsed"
                            Click="ClearSearchButton_OnClick" />
                    <StackPanel HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Margin="0,0,8,0">
                        <Button x:Name="ArchiveSearchButton"
                                Style="{StaticResource ArchiveSearchButtonStyle}"
                                Content="{Binding ArchiveSearchButtonText, RelativeSource={RelativeSource AncestorType=Window}}"
                                Visibility="Collapsed"
                                Click="ArchiveSearchButton_OnClick" />
                    </StackPanel>
                    <Popup x:Name="SearchResultsPopup"
                           PlacementTarget="{Binding ElementName=SearchTextBox}"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           StaysOpen="True"
                           VerticalOffset="4">
                        <Border Width="{Binding ElementName=SearchTextBox, Path=ActualWidth}"
                                Background="{DynamicResource Brush.PanelBg}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="6"
                                MaxHeight="400">
                            <ListBox x:Name="SearchResultsListBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ItemContainerStyle="{StaticResource ParticipantListItemStyle}"
                                     SelectionChanged="SearchResultsListBox_OnSelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:ParticipantIndexEntry}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Style="{StaticResource StatusTagBadgeStyle}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StatusTag}" Style="{StaticResource StatusTagTextStyle}" />
                                                </Border>
                                                <Grid Grid.Column="1"
                                                      Style="{StaticResource StatusTextColumnStyle}"
                                                      VerticalAlignment="Center">
                                                    <StackPanel VerticalAlignment="Center"
                                                                Style="{StaticResource ParticipantTextWithInitialsPanelStyle}">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Initials}"
                                                                       Style="{StaticResource ParticipantInitialsTextStyle}" />
                                                            <ItemsControl ItemsSource="{Binding HintMarkers}"
                                                                          Style="{StaticResource ParticipantHintMarkerItemsStyle}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <StackPanel Orientation="Horizontal" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Ellipse Width="6"
                                                                                 Height="6"
                                                                                 Margin="0,0,4,0"
                                                                                 Fill="{Binding MarkerColor}"
                                                                                 ToolTip="{Binding Text}" />
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Style="{StaticResource ParticipantNameWithInitialsTextStyle}" />
                                                    </StackPanel>
                                                    <StackPanel Style="{StaticResource ParticipantTextWithoutInitialsPanelStyle}">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Style="{StaticResource ParticipantNameTextStyle}"
                                                                   VerticalAlignment="Center" />
                                                        <ItemsControl ItemsSource="{Binding HintMarkers}"
                                                                      Style="{StaticResource ParticipantHintMarkerItemsStyle}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Ellipse Width="6"
                                                                             Height="6"
                                                                             Margin="0,0,4,0"
                                                                             Fill="{Binding MarkerColor}"
                                                                             ToolTip="{Binding Text}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                            <WrapPanel Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right">
                                                <Button Style="{StaticResource QuickActionButtonStyle}" Content="Ordner" Tag="folder"
                                                        Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=folder}"
                                                        PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                                <Button Style="{StaticResource QuickActionButtonStyle}" Content="Akte" Tag="document"
                                                        IsEnabled="{Binding DataContext.IsWordActionRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"
                                                        Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=document}"
                                                        PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                                <Button Style="{StaticResource QuickActionButtonStyle}" Content="BU" Tag="bu"
                                                        IsEnabled="{Binding DataContext.IsWordActionRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"
                                                        Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=bu}"
                                                        PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                                <Button Style="{StaticResource QuickActionButtonStyle}" Content="BI" Tag="bi"
                                                        IsEnabled="{Binding DataContext.IsWordActionRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"
                                                        Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=bi}"
                                                        PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                                <Button Style="{StaticResource QuickActionButtonStyle}" Content="BE" Tag="be"
                                                        IsEnabled="{Binding DataContext.IsWordActionRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"
                                                        Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=be}"
                                                        PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                                <Button Style="{StaticResource QuickActionButtonStyle}" Content="LB" Tag="lb"
                                                        IsEnabled="{Binding DataContext.IsWordActionRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"
                                                        Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=lb}"
                                                        PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                                <Button Style="{StaticResource QuickActionButtonStyle}" Content="Eintrag BU" Tag="entry_bu"
                                                        IsEnabled="{Binding DataContext.IsWordActionRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"
                                                        Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=entry_bu}"
                                                        PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                                <Button Style="{StaticResource QuickActionButtonStyle}" Content="Eintrag BI" Tag="entry_bi"
                                                        IsEnabled="{Binding DataContext.IsWordActionRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"
                                                        Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=entry_bi}"
                                                        PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                                <Button Style="{StaticResource QuickActionButtonStyle}" Content="Eintrag BE" Tag="entry_be"
                                                        IsEnabled="{Binding DataContext.IsWordActionRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"
                                                        Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=entry_be}"
                                                        PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                                <Button Style="{StaticResource QuickActionButtonStyle}" Content="Eintrag LB" Tag="entry_lb"
                                                        IsEnabled="{Binding DataContext.IsWordActionRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"
                                                        Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=entry_lb}"
                                                        PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                            </WrapPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>

                <StackPanel x:Name="TopBarActionsPanel" Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="DecreaseUiScaleButton"
                            Style="{StaticResource ScaleAdjustButtonStyle}"
                            Content="−"
                            ToolTip="Ansicht kompakter"
                            Click="DecreaseUiScaleButton_OnClick" />
                    <Button x:Name="IncreaseUiScaleButton"
                            Style="{StaticResource ScaleAdjustButtonStyle}"
                            Content="+"
                            ToolTip="Ansicht vergrössern"
                            Click="IncreaseUiScaleButton_OnClick" />
                    <Button x:Name="ToggleNotesPanelButton"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Notizen"
                            Padding="10,4"
                            Margin="0,0,6,0"
                            ToolTip="Notizspalte ein-/ausblenden"
                            Click="ToggleNotesPanelButton_OnClick" />
                    <Button x:Name="ToggleDetailPanelButton"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Details"
                            Padding="10,4"
                            Margin="0,0,6,0"
                            ToolTip="Detailbereich ein-/ausblenden"
                            Click="ToggleDetailPanelButton_OnClick" />
                    <Button x:Name="RefreshIndexButton"
                            Style="{StaticResource GhostButtonStyle}"
                            ToolTip="Index aktualisieren"
                            Click="RefreshButton_OnClick"
                            Margin="0,0,4,0"
                            Padding="0"
                            Width="{DynamicResource Ui.Size.IconButton}"
                            Height="{DynamicResource Ui.Size.IconButton}">
                        <Image Source="Assets/Reload.secondary.png"
                               Width="15"
                               Height="15"
                               Margin="0,-1,0,0"
                               Stretch="Uniform"
                               SnapsToDevicePixels="True"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Button>
                    <Button x:Name="SettingsButton"
                            Style="{StaticResource GhostButtonStyle}"
                            ToolTip="Einstellungen"
                            Click="SettingsButton_OnClick"
                            Padding="0"
                            Width="{DynamicResource Ui.Size.IconButton}"
                            Height="{DynamicResource Ui.Size.IconButton}">
                        <Image Source="Assets/Einstellungen.secondary.png"
                               Width="15"
                               Height="15"
                               Stretch="Uniform"
                               SnapsToDevicePixels="True"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ListPanelColumn" Width="200" MinWidth="132" />
                <ColumnDefinition x:Name="ListPanelSplitterColumn" Width="6" />
                <ColumnDefinition x:Name="MainContentColumn" Width="*" MinWidth="180" />
                <ColumnDefinition x:Name="NotesPanelSplitterColumn" Width="0" />
                <ColumnDefinition x:Name="NotesPanelColumn" Width="0" MinWidth="0" />
                <ColumnDefinition x:Name="DetailPanelSplitterColumn" Width="6" />
                <ColumnDefinition x:Name="DetailPanelColumn" Width="220" MinWidth="220" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ListPanelBorder" Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Padding="10">
                <Grid x:Name="ListPanelContentGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="ListPanelHeaderGrid" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Listen" FontSize="{DynamicResource Ui.Font.SectionTitle}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button x:Name="NewListButton"
                                Grid.Column="1"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="+"
                                FontSize="{DynamicResource Ui.Font.IconAction}"
                                FontWeight="SemiBold"
                                Width="{DynamicResource Ui.Size.IconButton}"
                                Height="{DynamicResource Ui.Size.IconButton}"
                                Padding="0"
                                Margin="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                ToolTip="Neue Liste erstellen"
                                Click="NewListButton_OnClick" />
                    </Grid>

                    <Button x:Name="WorkspaceButton"
                            Grid.Row="1"
                            Style="{StaticResource GhostButtonStyle}"
                            HorizontalContentAlignment="Left"
                            Padding="8,6"
                            Margin="0,0,0,4"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            Click="WorkspaceButton_OnClick">
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock x:Name="WorkspaceTitleTextBlock"
                                       Text="Temporäre Liste" FontSize="{DynamicResource Ui.Font.SidebarName}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.PrimaryText}" TextAlignment="Left" />
                            <TextBlock x:Name="WorkspaceCountText" Text="Leer" FontSize="{DynamicResource Ui.Font.SidebarMeta}"
                                       Foreground="{DynamicResource Brush.SecondaryText}" Margin="0,1,0,0"
                                       TextAlignment="Left" />
                        </StackPanel>
                    </Button>

                    <ListBox x:Name="ListsListBox" Grid.Row="2"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemContainerStyle="{StaticResource SidebarListItemStyle}"
                             SelectionChanged="ListsListBox_OnSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SavedList}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="{DynamicResource Ui.Font.SidebarName}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.PrimaryText}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Items.Count, StringFormat={}{0} TN}" FontSize="{DynamicResource Ui.Font.SidebarMeta}"
                                                   Foreground="{DynamicResource Brush.SecondaryText}" Margin="0,1,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Tag="{Binding Id}" Style="{StaticResource GhostButtonStyle}"
                                            Content="⋯" FontSize="{DynamicResource Ui.Font.IconAction}" Width="{DynamicResource Ui.Size.IconButton}" Height="{DynamicResource Ui.Size.IconButton}" Padding="0" Margin="0"
                                            VerticalAlignment="Center" Click="ListOptionsButton_OnClick">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Umbenennen" Tag="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Click="RenameListMenuItem_OnClick" />
                                                <MenuItem Header="Löschen" Tag="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Click="DeleteListMenuItem_OnClick" />
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="ListsEmptyState" Grid.Row="2"
                               Text="Noch keine Listen vorhanden."
                               Foreground="{DynamicResource Brush.SubtleText}"
                               FontSize="{DynamicResource Ui.Font.SidebarMeta}"
                               TextWrapping="Wrap"
                               Margin="4,12,4,0"
                               Visibility="Collapsed" />

                    <Button x:Name="ImportAttendanceButton"
                            Grid.Row="3"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Liste importieren"
                            HorizontalAlignment="Stretch"
                            Margin="0,8,0,0"
                            Padding="8,6"
                            Click="ImportAttendanceButton_OnClick" />
                </Grid>
            </Border>

            <GridSplitter x:Name="ListPanelSplitter"
                          Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          ShowsPreview="False" />
            <Grid x:Name="MainAreaBorder" Grid.Column="2" Margin="8,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border x:Name="CurrentListHeaderBorder"
                        Grid.Row="0"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="12,10"
                        Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="CurrentListTitleTextBlock" FontSize="{DynamicResource Ui.Font.CurrentListTitle}" FontWeight="SemiBold"
                                           Text="Temporäre Liste" VerticalAlignment="Center" />
                                <Border x:Name="SavedBadge" Background="{DynamicResource Brush.AccentSubtle}"
                                        CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                        VerticalAlignment="Center" Visibility="Collapsed">
                                    <TextBlock Text="Gespeichert" FontSize="{DynamicResource Ui.Font.StatusTag}"
                                               Foreground="{DynamicResource Brush.Accent}" FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>
                            <TextBlock x:Name="CurrentListSubtitleTextBlock" Margin="0,2,0,0"
                                       Foreground="{DynamicResource Brush.SecondaryText}" FontSize="{DynamicResource Ui.Font.CurrentListSubtitle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="ClearWorkingListButton"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Leeren"
                                    Padding="8,0"
                                    MinHeight="{DynamicResource Ui.Size.WorkingButtonMinHeight}"
                                    FontSize="{DynamicResource Ui.Font.SidebarMeta}"
                                    Click="ClearWorkingListButton_OnClick"
                                    Visibility="Collapsed" />
                            <Button x:Name="SaveWorkingListButton"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Speichern"
                                    Padding="8,0"
                                    MinHeight="{DynamicResource Ui.Size.WorkingButtonMinHeight}"
                                    FontSize="{DynamicResource Ui.Font.SidebarMeta}"
                                    Click="SaveWorkingListButton_OnClick"
                                    Visibility="Collapsed" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border x:Name="CurrentListParticipantsBorder"
                        Grid.Row="1"
                        Background="{DynamicResource Brush.PanelBg}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10">
                    <Grid>
                        <ListBox x:Name="CurrentListParticipantsListBox"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ItemContainerStyle="{StaticResource WorkingListItemStyle}"
                                 SelectionChanged="CurrentListParticipantsListBox_OnSelectionChanged" MouseDoubleClick="CurrentListParticipantsListBox_OnMouseDoubleClick">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ParticipantIndexEntry}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Style="{StaticResource StatusTagBadgeStyle}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StatusTag}" Style="{StaticResource StatusTagTextStyle}" />
                                            </Border>
                                            <Grid Grid.Column="1"
                                                  Style="{StaticResource StatusTextColumnStyle}"
                                                  VerticalAlignment="Center">
                                                <StackPanel VerticalAlignment="Center"
                                                            Style="{StaticResource ParticipantTextWithInitialsPanelStyle}">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Initials}"
                                                                   Style="{StaticResource ParticipantInitialsTextStyle}" />
                                                        <ItemsControl ItemsSource="{Binding HintMarkers}"
                                                                      Style="{StaticResource ParticipantHintMarkerItemsStyle}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Ellipse Width="6"
                                                                             Height="6"
                                                                             Margin="0,0,4,0"
                                                                             Fill="{Binding MarkerColor}"
                                                                             ToolTip="{Binding Text}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Style="{StaticResource ParticipantNameWithInitialsTextStyle}" />
                                                </StackPanel>
                                                <StackPanel Style="{StaticResource ParticipantTextWithoutInitialsPanelStyle}">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Style="{StaticResource ParticipantNameTextStyle}"
                                                               VerticalAlignment="Center" />
                                                    <ItemsControl ItemsSource="{Binding HintMarkers}"
                                                                  Style="{StaticResource ParticipantHintMarkerItemsStyle}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Ellipse Width="6"
                                                                         Height="6"
                                                                         Margin="0,0,4,0"
                                                                         Fill="{Binding MarkerColor}"
                                                                         ToolTip="{Binding Text}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>

                                            <WrapPanel x:Name="CurrentParticipantActionsPanel"
                                                   Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   Margin="12,0,0,0">
                                            <Button Style="{StaticResource QuickActionButtonStyle}" Content="Ordner" Tag="folder"
                                                    Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=folder}"
                                                    PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                            <Button Style="{StaticResource QuickActionButtonStyle}" Content="Akte" Tag="document"
                                                    IsEnabled="{Binding DataContext.IsWordActionRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"
                                                    Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=document}"
                                                    PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                            <Button Style="{StaticResource QuickActionButtonStyle}" Content="BU" Tag="bu"
                                                    IsEnabled="{Binding DataContext.IsWordActionRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"
                                                    Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=bu}"
                                                    PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                            <Button Style="{StaticResource QuickActionButtonStyle}" Content="BI" Tag="bi"
                                                    IsEnabled="{Binding DataContext.IsWordActionRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"
                                                    Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=bi}"
                                                    PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                            <Button Style="{StaticResource QuickActionButtonStyle}" Content="BE" Tag="be"
                                                    IsEnabled="{Binding DataContext.IsWordActionRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"
                                                    Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=be}"
                                                    PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                            <Button Style="{StaticResource QuickActionButtonStyle}" Content="LB" Tag="lb"
                                                    IsEnabled="{Binding DataContext.IsWordActionRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"
                                                    Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=lb}"
                                                    PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                            <Button Style="{StaticResource QuickActionButtonStyle}" Content="Eintrag BU" Tag="entry_bu"
                                                    IsEnabled="{Binding DataContext.IsWordActionRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"
                                                    Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=entry_bu}"
                                                    PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                            <Button Style="{StaticResource QuickActionButtonStyle}" Content="Eintrag BI" Tag="entry_bi"
                                                    IsEnabled="{Binding DataContext.IsWordActionRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"
                                                    Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=entry_bi}"
                                                    PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                            <Button Style="{StaticResource QuickActionButtonStyle}" Content="Eintrag BE" Tag="entry_be"
                                                    IsEnabled="{Binding DataContext.IsWordActionRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"
                                                    Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=entry_be}"
                                                    PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                            <Button Style="{StaticResource QuickActionButtonStyle}" Content="Eintrag LB" Tag="entry_lb"
                                                    IsEnabled="{Binding DataContext.IsWordActionRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"
                                                    Visibility="{Binding DataContext.VisibleQuickActions, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource QuickActionVisibilityConverter}, ConverterParameter=entry_lb}"
                                                    PreviewMouseLeftButtonDown="QuickActionButton_OnPreviewMouseLeftButtonDown" />
                                        </WrapPanel>

                                        <Button x:Name="CurrentParticipantRemoveButton"
                                                Grid.Column="2"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Content="×"
                                                FontSize="{DynamicResource Ui.Font.IconAction}"
                                                ToolTip="Entfernen"
                                                Width="{DynamicResource Ui.Size.IconButton}"
                                                Height="{DynamicResource Ui.Size.IconButton}"
                                                Padding="0"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                Focusable="False"
                                                PreviewMouseLeftButtonDown="RemoveParticipantButton_OnPreviewMouseLeftButtonDown"
                                                Tag="{Binding ParticipantKey}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid x:Name="WorkingAreaEmptyState" Visibility="Collapsed" />
                    </Grid>
                </Border>
            </Grid>
            <GridSplitter x:Name="NotesPanelSplitter"
                          Grid.Column="3"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          ShowsPreview="False"
                          Visibility="Collapsed" />

            <Border x:Name="NotesPanelBorder"
                    Grid.Column="4"
                    Style="{StaticResource PanelBorderStyle}"
                    MinWidth="364"
                    Visibility="Collapsed">
                <controls:ParticipantNotesPanel x:Name="NotesPanel" />
            </Border>

            <GridSplitter x:Name="DetailPanelSplitter"
                          Grid.Column="5"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          ShowsPreview="False"
                          Visibility="Collapsed" />

            <Border x:Name="DetailPanelBorder"
                    Grid.Column="6"
                    Style="{StaticResource PanelBorderStyle}"
                    Margin="2,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Teilnehmerdetails"
                                   FontSize="{DynamicResource Ui.Font.SectionTitle}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                x:Name="CloseDetailPanelButton"
                                Style="{StaticResource GhostButtonStyle}"
                                Content="×"
                                Width="{DynamicResource Ui.Size.IconButton}"
                                Height="{DynamicResource Ui.Size.IconButton}"
                                Padding="0"
                                ToolTip="Detailbereich schliessen"
                                Click="CloseDetailPanelButton_OnClick" />
                    </Grid>

                    <controls:ParticipantDetailPanel x:Name="DetailPanel" Grid.Row="1" />
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="StatusBarBorder" Grid.Row="2" Style="{StaticResource PanelBorderStyle}" Margin="0,8,0,8" Padding="10,6">
            <DockPanel>
                <TextBlock x:Name="IndexStateTextBlock" DockPanel.Dock="Right"
                           Margin="14,0,0,0"
                           Foreground="{DynamicResource Brush.SecondaryText}" FontSize="{DynamicResource Ui.Font.CurrentListSubtitle}"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusTextBlock" Text="Bereit" FontSize="{DynamicResource Ui.Font.StatusBar}" VerticalAlignment="Center" />
                    <StackPanel x:Name="EvaluateProgressPanel"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="10,0,0,0"
                                Visibility="Collapsed">
                        <ProgressBar x:Name="EvaluateProgressBar"
                                     Width="72"
                                     Height="6"
                                     IsIndeterminate="True"
                                     Style="{StaticResource SubtleProgressBarStyle}"
                                     VerticalAlignment="Center" />
                        <TextBlock Text="läuft"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="{DynamicResource Ui.Font.CurrentListSubtitle}"
                                   Foreground="{DynamicResource Brush.SecondaryText}" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>




































