                                        <TextBlock x:Name="ScheduleFrNmTeacherTextBlock" Grid.Column="0" FontSize="8" Foreground="{DynamicResource Brush.SecondaryText}" TextWrapping="NoWrap" HorizontalAlignment="Left" Margin="1,0,0,0" />
                                        <TextBlock x:Name="ScheduleFrNmRoomTextBlock" Grid.Column="2" FontSize="7.6" Foreground="{DynamicResource Brush.SecondaryText}" TextWrapping="NoWrap" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,2,0" />
                                    </Grid>
                                    <TextBlock x:Name="ScheduleFrNmAdditionalTextBlock" Grid.Row="2" Margin="0,0,0,0" FontSize="6.4" Foreground="{DynamicResource Brush.SubtleText}" TextWrapping="NoWrap" TextAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed" />
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>



































