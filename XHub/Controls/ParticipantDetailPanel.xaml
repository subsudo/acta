                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="ScheduleFrNmPrimaryTextBlock" Grid.Row="0" FontWeight="SemiBold" FontSize="10" TextWrapping="NoWrap" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0" TextAlignment="Center" />
                                    <Grid Grid.Row="1" Margin="0,0,0,0" HorizontalAlignment="Center">
