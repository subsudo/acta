<Window x:Class="XHub.Views.NoticeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hinweis"
        Width="420"
        Height="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.WindowBg}"
        Foreground="{DynamicResource Brush.PrimaryText}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource Brush.SoftSurface}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12"
                Margin="0,0,0,14">
            <DockPanel LastChildFill="True">
                <Border Width="36"
                        Height="36"
                        CornerRadius="18"
                        Background="#FFF6E5"
                        BorderBrush="#F2D8A7"
                        BorderThickness="1"
                        Margin="0,0,10,0">
                    <TextBlock Text="!"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#B7791F"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <StackPanel>
                    <TextBlock x:Name="TitleTextBlock"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.PrimaryText}" />
                    <TextBlock x:Name="SubtitleTextBlock"
                               Margin="0,4,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource Brush.SecondaryText}"
                               Text="Bitte spaeter erneut versuchen." />
                </StackPanel>
            </DockPanel>
        </Border>

        <TextBlock x:Name="MessageTextBlock"
                   Grid.Row="1"
                   TextWrapping="Wrap"
                   FontSize="13"
                   LineHeight="20"
                   Foreground="{DynamicResource Brush.PrimaryText}" />

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="OK"
                    Width="96"
                    Click="OkButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>
