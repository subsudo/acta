<Window x:Class="XHub.Views.TextPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Eingabe"
        Width="420"
        Height="190"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.WindowBg}"
        Foreground="{DynamicResource Brush.PrimaryText}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock x:Name="PromptTextBlock" Margin="0,0,0,10" TextWrapping="Wrap" />
        <TextBox x:Name="ValueTextBox" Grid.Row="1" MinWidth="320" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Abbrechen" Width="100" Margin="0,0,8,0" Click="CancelButton_OnClick" />
            <Button Content="OK" Width="100" Click="OkButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>
