<Window x:Class="XHub.Views.AttendanceImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Liste importieren"
        Width="700"
        Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.WindowBg}"
        Foreground="{DynamicResource Brush.PrimaryText}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Text aus einer Liste oder Tagesansicht einfügen. Der Import bleibt temporär und wird nicht gespeichert."
                   FontSize="16"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />

        <TextBox x:Name="RawInputTextBox"
                 Grid.Row="1"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"
                 FontFamily="Consolas" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Abbrechen" Width="110" Margin="0,0,8,0" Click="CancelButton_OnClick" />
            <Button Content="Importieren" Width="110" Click="ImportButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>
