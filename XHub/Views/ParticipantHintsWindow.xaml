<Window x:Class="XHub.Views.ParticipantHintsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:XHub.Models"
        Title="{Binding WindowTitle}"
        Width="540"
        Height="620"
        MinWidth="480"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.WindowBg}"
        Foreground="{DynamicResource Brush.PrimaryText}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="HintFieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.SecondaryText}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,6,0,3" />
        </Style>

        <Style x:Key="HintTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Brush.CardBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="HintDatePicker" TargetType="DatePicker">
            <Setter Property="Background" Value="{DynamicResource Brush.CardBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="HintButton" TargetType="Button">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="Background" Value="{DynamicResource Brush.CardBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryHintButton" TargetType="Button" BasedOn="{StaticResource HintButton}">
            <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <DataTemplate x:Key="ActiveHintTemplate" DataType="{x:Type models:ParticipantHintEditorItem}">
            <Border Margin="0,0,0,9"
                    Padding="11"
                    Background="{DynamicResource Brush.CardBg}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding TypeLabel}" FontWeight="SemiBold" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource HintButton}"
                                Content="Erledigt"
                                Tag="{Binding}"
                                Click="MarkDoneButton_OnClick" />
                        <Button Style="{StaticResource HintButton}"
                                Content="Löschen"
                                Tag="{Binding}"
                                Click="DeleteHintButton_OnClick" />
                    </StackPanel>

                    <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Visibility="{Binding ShowDate, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Style="{StaticResource HintFieldLabel}" Text="Datum" />
                            <DatePicker Style="{StaticResource HintDatePicker}"
                                        SelectedDate="{Binding DateValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="0"
                                    Grid.ColumnSpan="3"
                                    Visibility="{Binding ShowText, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Style="{StaticResource HintFieldLabel}" Text="Notiz (max. 60 Zeichen)" />
                            <TextBox Style="{StaticResource HintTextBox}"
                                     MaxLength="60"
                                     MinHeight="52"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Disabled"
                                     Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DoneHintTemplate" DataType="{x:Type models:ParticipantHintEditorItem}">
            <Border Margin="0,0,0,7"
                    Padding="9"
                    Background="{DynamicResource Brush.CardHover}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="7"
                    Opacity="0.78">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Style="{StaticResource HintButton}"
                                Content="Reaktivieren"
                                Tag="{Binding}"
                                Click="ReactivateHintButton_OnClick" />
                        <Button Style="{StaticResource HintButton}"
                                Content="Löschen"
                                Tag="{Binding}"
                                Click="DeleteHintButton_OnClick" />
                    </StackPanel>
                    <TextBlock Text="{Binding TypeLabel}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding WindowTitle}"
                       FontSize="17"
                       FontWeight="SemiBold" />
            <TextBlock Text="Aktive Hinweise erscheinen als farbige Markierungen und kompakte Hinweise."
                       Foreground="{DynamicResource Brush.SecondaryText}"
                       Margin="0,4,0,12" />
        </StackPanel>

        <WrapPanel Grid.Row="1" Margin="0,0,0,12">
            <Button Style="{StaticResource HintButton}" Content="+ Austritt" Click="AddExitButton_OnClick" />
            <Button Style="{StaticResource HintButton}" Content="+ AM-Bericht" Click="AddAmButton_OnClick" />
            <Button Style="{StaticResource HintButton}" Content="+ Stellwerk-Test" Click="AddStellwerkButton_OnClick" />
            <Button Style="{StaticResource HintButton}" Content="+ Notiz" Click="AddFreeButton_OnClick" />
        </WrapPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Aktive Hinweise"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding ActiveItems}" ItemTemplate="{StaticResource ActiveHintTemplate}" />

                <TextBlock Text="Erledigte Hinweise"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.SecondaryText}"
                           Margin="0,12,0,8" />
                <ItemsControl ItemsSource="{Binding DoneItems}" ItemTemplate="{StaticResource DoneHintTemplate}" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Style="{StaticResource HintButton}"
                    Content="Abbrechen"
                    Click="CancelButton_OnClick" />
            <Button Style="{StaticResource PrimaryHintButton}"
                    Content="Speichern"
                    Click="SaveButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>
